rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);

      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scanRecords/{docId} {
      allow create: if (isSignedIn() || request.resource.data.userId == 'guest')
        && request.resource.data.keys().hasAll(['userId', 'skinType', 'createdAt']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /guestVerifications/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /adminStats/{docId} {
      allow read, write: if isAdmin();
    }

    match /adConfigs/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /history/{historyId} {
        allow read, write: if isAdmin();
      }
    }

    match /adConfigDrafts/{docId} {
      allow read, write: if isAdmin();
    }

    match /adEvents/{docId} {
      allow create: if request.resource.data.keys().hasAll(
        ['adId', 'pool', 'message', 'type', 'userId', 'createdAt']
      )
      && request.resource.data.type in ['impression', 'click'];
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /adStats/{docId} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.keys().hasAll(
        ['pool', 'message', 'impressions', 'clicks', 'ctr']
      );
      allow delete: if isAdmin();
    }
  }
}
